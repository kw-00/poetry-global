{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Issuer": "PoetryGlobal",
    "LifetimeMinutes": 60
  },
  "ExternalApis": {
    "PoetryDb": {
      "BaseUrl": "https://poetrydb.org"
    },
    "MyMemory": {
      "BaseUrl": "https://api.mymemory.translated.net"
    }
  },
  "Features": {
    "Poems": {
      "Search": {
        "ExternalPoetryAPIBatchSize": 200,
        "DatabaseBatchSize": 200,
        "PreferredMinBatchSize": 200,
        "MinSuccessfulSaveRatio": 0.5,
        "PageSize": 20,
        "PageCacheSlidingLifetimeSeconds": 1800,
        "PageCacheAbsoluteLifetimeMinutes": 30
      }
    }
  }
}
