{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Issuer": "PoetryGlobal",
    "LifetimeMinutes": 60
  },
  "ExternalApis": {
    "PoetryDb": {
      "BaseUrl": "https://poetrydb.org"
    },
    "MyMemory": {
      "BaseUrl": "https://api.mymemory.translated.net"
    }
  },
  "Features": {
    "Poems": {
      "PoetryDbSearchBatchSize": 100,
      "DatabaseSearchBatchSize": 200,
      "PageSize": 20,
      "PageCacheCleanupIntervalSeconds": 1800,
      "PageCacheLifetimeSeconds": 300
    }
  }
}
