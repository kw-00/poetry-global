{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Issuer": "PoetryGlobal",
    "LifetimeMinutes": 60
  },
  "ExternalApis": {
    "PoetryDb": {
      "BaseUrl": "https://poetrydb.org/"
    },
    "MyMemory": {
      "BaseUrl": "https://api.mymemory.translated.net/"
    }
  },
  "Features": {
    "Poems": {
      "PoetryDbBatchSize": 100,
      "DatabaseBatchSize": 200,
      "PageSize": 20
    }
  }
}
